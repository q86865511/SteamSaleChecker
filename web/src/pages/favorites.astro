---
import Base from '../layouts/Base.astro';
---
<Base>
  <header class="head">
    <div>
      <h1 data-i18n="favTitle">我的收藏</h1>
      <p class="muted small"><a href="/" data-i18n="backToDeals">← 返回特價</a></p>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <span id="auth-control"></span>
      <button id="theme-toggle" class="lang-btn" type="button" aria-label="切換主題">🌙</button>
      <button id="lang-toggle" class="lang-btn">EN</button>
    </div>
  </header>

  <section id="steam-import" hidden>
    <div class="import-box">
      <span class="set-label" data-i18n="importSteamTitle">從 Steam 願望單匯入</span>
      <input id="steam-id-input" type="text" class="target-input" style="width:auto;min-width:240px"
             data-i18n-ph="importSteamPh" data-i18n-aria="importSteamTitle" placeholder="SteamID64 或個人檔網址" aria-label="SteamID" />
      <button id="steam-import-btn" class="ctl-btn" type="button" data-i18n="importSteamBtn">匯入</button>
      <span id="steam-import-status" class="muted small" role="status"></span>
    </div>
    <p class="muted small" data-i18n="importSteamHint">願望單需在 Steam 個人檔設為公開。</p>
  </section>

  <section><div id="fav-list"></div></section>

  <script>
    import { bootFavorites } from '../scripts/favorites';
    bootFavorites();
  </script>
</Base>
