---
import Base from '../layouts/Base.astro';
---
<Base>
  <header class="head">
    <div>
      <h1 data-i18n="settingsTitle">設定</h1>
      <p class="muted small"><a href="/" data-i18n="backToDeals">← 返回特價</a></p>
    </div>
  </header>

  <section class="settings">
    <div class="set-row">
      <span class="set-label" data-i18n="themeLabel">主題</span>
      <div class="seg" id="theme-seg" role="group" data-i18n-aria="themeLabel" aria-label="主題">
        <button class="seg-btn" type="button" data-theme-choice="system" data-i18n="themeSystem">跟隨系統</button>
        <button class="seg-btn" type="button" data-theme-choice="dark" data-i18n="themeDark">深色</button>
        <button class="seg-btn" type="button" data-theme-choice="light" data-i18n="themeLight">淺色</button>
      </div>
    </div>
    <div class="set-row">
      <span class="set-label" data-i18n="langLabel">語言</span>
      <div class="seg" id="lang-seg" role="group" data-i18n-aria="langLabel" aria-label="語言">
        <button class="seg-btn" type="button" data-lang-choice="zh-TW">繁體中文</button>
        <button class="seg-btn" type="button" data-lang-choice="en">English</button>
      </div>
    </div>
    <div class="set-row">
      <span class="set-label" data-i18n="viewLabel">預設檢視</span>
      <div class="seg" id="view-seg" role="group" data-i18n-aria="viewLabel" aria-label="預設檢視">
        <button class="seg-btn" type="button" data-view-choice="list" data-i18n="viewList">列表</button>
        <button class="seg-btn" type="button" data-view-choice="card" data-i18n="viewCard">卡片</button>
      </div>
    </div>
    <p class="muted small" data-i18n="notifyPrefsSoon" style="margin-top:20px">通知偏好(即將推出)</p>
  </section>

  <script>
    import { bootSettings } from '../scripts/settings';
    bootSettings();
  </script>
</Base>
