---
import Base from '../layouts/Base.astro';
---
<Base>
  <header class="head">
    <div>
      <h1 data-i18n="title">Steam 特價追蹤</h1>
      <p class="muted" data-i18n="subtitle">熱銷特價 · 本站自建價格追蹤</p>
      <p class="muted small" id="meta"></p>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <span id="auth-control"></span>
      <button id="theme-toggle" class="lang-btn" type="button" aria-label="切換主題">🌙</button>
      <button id="lang-toggle" class="lang-btn">EN</button>
      <a class="gear-link" href="/favorites" data-i18n-aria="favLink" aria-label="收藏">♥</a>
      <a class="gear-link" href="/settings" data-i18n-aria="settingsLink" aria-label="設定">⚙</a>
    </div>
  </header>

  <section id="ending-soon-sec" hidden>
    <h2 data-i18n="endingSoon">即將結束</h2>
    <div class="grid" id="ending-soon"></div>
  </section>

  <section id="deals-section">
    <div class="toolbar">
      <h2 data-i18n="deals">熱門特價榜</h2>
      <div class="toolbar-controls">
        <input id="deal-search" type="search" class="search-input" data-i18n-ph="searchPlaceholder"
               data-i18n-aria="searchPlaceholder" placeholder="搜尋遊戲…" autocomplete="off" aria-label="搜尋遊戲" />
        <label class="sr-only" for="sort-select" data-i18n="sortLabel">排序</label>
        <select id="sort-select" class="ctl-select">
          <option value="rank-asc" data-i18n="sortRank">推薦排序</option>
          <option value="discount-desc" data-i18n="sortDiscountDesc">折扣 高→低</option>
          <option value="price-asc" data-i18n="sortPriceAsc">價格 低→高</option>
          <option value="price-desc" data-i18n="sortPriceDesc">價格 高→低</option>
        </select>
        <button id="view-toggle" class="ctl-btn" type="button" data-i18n="viewCard">卡片</button>
        <label class="filter-ctl"><span data-i18n="filterDiscount">最低折扣</span>
          <select id="filter-discount" class="ctl-select">
            <option value="0" data-i18n="filterAny">不限</option>
            <option value="25">25%+</option>
            <option value="50">50%+</option>
            <option value="75">75%+</option>
            <option value="90">90%+</option>
          </select>
        </label>
        <label class="filter-ctl"><span data-i18n="filterMaxPrice">最高價(NT$)</span>
          <input id="filter-maxprice" type="number" min="0" step="50" inputmode="numeric" />
        </label>
        <label class="filter-ctl"><span data-i18n="filterType">類型</span>
          <select id="filter-type" class="ctl-select">
            <option value="" data-i18n="filterTypeAny">全部類型</option>
          </select>
        </label>
        <label class="filter-ctl"><input id="filter-atlow" type="checkbox" /> <span data-i18n="filterAtLow">只看 ≤ 史低</span></label>
      </div>
    </div>
    <div id="deals-host" data-view="list"></div>
  </section>

  <section>
    <h2 data-i18n="free">免費領取</h2>
    <div class="grid" id="free"></div>
  </section>

  <section class="about">
    <h2 data-i18n="aboutTitle">關於這個專案</h2>
    <p class="muted" id="about-body" style="max-width:760px"></p>
  </section>

  <script>
    import { boot } from '../scripts/app';
    boot();
  </script>
</Base>
