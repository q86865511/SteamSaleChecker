DISCORD_CLIENT_ID=your-client-id
DISCORD_CLIENT_SECRET=your-client-secret
DISCORD_REDIRECT_URI=http://localhost:8787/auth/callback
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-characters
WEB_ORIGIN=http://localhost:4321
API_PORT=8787
SSC_DB=
# ^ 留空即用預設 data/steam.db(worker 與 api 共用)
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_NOTIFY_CHANNEL_ID=your-channel-id
COOKIE_SECURE=false
# ^ 線上(https)請設 true
ITAD_API_KEY=
# ^ 僅供「一次性 ITAD 史低 seed」(npm -w @ssc/worker run seed);平時 production 不需要
# --- 線上(prod)參考值 ---
