DISCORD_CLIENT_ID=your-client-id
DISCORD_CLIENT_SECRET=your-client-secret
DISCORD_REDIRECT_URI=http://localhost:8787/auth/callback
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-characters
WEB_ORIGIN=http://localhost:4321
API_PORT=8787
SSC_DB=
# ^ 留空即用預設 data/steam.db(worker 與 api 共用)
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_NOTIFY_CHANNEL_ID=your-channel-id
DISCORD_BOT_INVITE_REDIRECT_URI=http://localhost:8787/api/bot/invite/callback
# ^ 「邀請機器人到自己伺服器」流程的回跳網址(與上面登入用 DISCORD_REDIRECT_URI 分開)。
#   需在 Discord 開發者後台 → OAuth2 → Redirects 另外註冊此網址,否則 Discord 不會回跳帶 guild_id;
#   並把 Bot 設為 Public Bot,非擁有者才能把它邀請進自己的伺服器。
COOKIE_SECURE=false
# ^ 線上(https)請設 true
ITAD_API_KEY=
# ^ ITAD 史低刷新金鑰(API Key,非 OAuth secret);設了 worker 會每日自動刷新史低
SSC_ITAD_REFRESH_HOURS=24
# ^ ITAD 自動刷新間隔(小時),預設 24
SSC_DIGEST_HOURS=0
# ^ 每日/每週特價摘要發 Discord 的間隔(小時):0=停用、24=每日、168=每週;需 BOT_TOKEN + NOTIFY_CHANNEL_ID
# --- 線上(prod)參考值 ---
# DISCORD_REDIRECT_URI=https://steam.terrychou.com/auth/callback
# DISCORD_BOT_INVITE_REDIRECT_URI=https://steam.terrychou.com/api/bot/invite/callback
# WEB_ORIGIN=https://steam.terrychou.com
# API_PORT=8788
